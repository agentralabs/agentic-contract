\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces AgenticContract architecture. Three integration surfaces (MCP, CLI, FFI) feed into the core \texttt  {ContractEngine}, which manages six governance primitive stores backed by a single \texttt  {.acon} binary file with BLAKE3 integrity verification.}}{3}{figure.caption.4}\protected@file@percent }
\newlabel{fig:architecture}{{2}{3}{AgenticContract architecture. Three integration surfaces (MCP, CLI, FFI) feed into the core \texttt {ContractEngine}, which manages six governance primitive stores backed by a single \texttt {.acon} binary file with BLAKE3 integrity verification}{figure.caption.4}{}}
