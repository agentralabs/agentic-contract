\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Policy evaluation time vs.\ policy count on a log--log scale. The measured data (blue) closely tracks the theoretical linear $O(n)$ baseline (gray dashed), confirming allocation-free iteration with a constant per-policy cost of approximately 70\,ns.}}{6}{figure.caption.11}\protected@file@percent }
\newlabel{fig:scaling}{{6}{6}{Policy evaluation time vs.\ policy count on a log--log scale. The measured data (blue) closely tracks the theoretical linear $O(n)$ baseline (gray dashed), confirming allocation-free iteration with a constant per-policy cost of approximately 70\,ns}{figure.caption.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces File I/O for 100 entities (50 policies + 50 risk limits). Save includes JSON serialization, BLAKE3 checksum computation, and atomic write (write-to-temporary then rename). Load includes file read, checksum verification, and JSON deserialization.}}{6}{table.caption.12}\protected@file@percent }
\newlabel{tab:io}{{5}{6}{File I/O for 100 entities (50 policies + 50 risk limits). Save includes JSON serialization, BLAKE3 checksum computation, and atomic write (write-to-temporary then rename). Load includes file read, checksum verification, and JSON deserialization}{table.caption.12}{}}
