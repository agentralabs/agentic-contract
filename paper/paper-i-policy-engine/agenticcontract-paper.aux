\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Core operation latencies. All operations complete in under 1.1\,\textmu {}s. Policy evaluation and risk limit checks are under 50\,ns---within the noise floor of a single LLM token generation step (typically 10--50\,ms).}}{5}{table.caption.9}\protected@file@percent }
\newlabel{tab:latency}{{3}{5}{Core operation latencies. All operations complete in under 1.1\,\textmu {}s. Policy evaluation and risk limit checks are under 50\,ns---within the noise floor of a single LLM token generation step (typically 10--50\,ms)}{table.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Policy evaluation scaling. Each 10$\times $ increase in policy count produces approximately 10$\times $ increase in evaluation time, confirming $O(n)$ complexity with a per-policy cost stabilizing at $\sim $70\,ns.}}{5}{table.caption.10}\protected@file@percent }
\newlabel{tab:scaling}{{4}{5}{Policy evaluation scaling. Each 10$\times $ increase in policy count produces approximately 10$\times $ increase in evaluation time, confirming $O(n)$ complexity with a per-policy cost stabilizing at $\sim $70\,ns}{table.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Core Operation Latency}{5}{subsection.4.2}\protected@file@percent }
